{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Local (.env)",
      "program": "${workspaceFolder}/node_modules/@nestjs/cli/bin/nest.js",
      "args": [
        "start",
        "--debug",
        "--watch"
      ],
      "runtimeArgs": [
        "--nolazy"
      ],
      "console": "integratedTerminal",
      "restart": true,
      "env": {
        "ENV_FILE": ".env"
      },
      "envFile": "${workspaceFolder}/.env",
      "sourceMaps": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Dev (.env.dev)",
      "program": "${workspaceFolder}/node_modules/@nestjs/cli/bin/nest.js",
      "args": [
        "start",
        "--debug",
        "--watch"
      ],
      "runtimeArgs": [
        "--nolazy"
      ],
      "console": "integratedTerminal",
      "restart": true,
      "env": {
        "ENV_FILE": ".env.dev"
      },
      "envFile": "${workspaceFolder}/.env.dev",
      "sourceMaps": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Debug: Attach",
      "port": 9229,
      "restart": true,
      "sourceMaps": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
